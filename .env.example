# ================================================================
# 自适应学习平台 环境变量配置示例
# 使用方法：cp .env.example .env，然后填写实际值
# 警告：.env 文件已加入 .gitignore，禁止提交到版本控制
# ================================================================

# ── 应用基础 ──────────────────────────────────────────────────
APP_ENV=development        # development | test | production
APP_DEBUG=true             # 生产环境必须设为 false

# ── 数据库 ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/adaptive_learning
# 生产环境示例：
# DATABASE_URL=postgresql+asyncpg://prod_user:STRONG_PASSWORD@db.internal:5432/adaptive_learning

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# 生产环境带密码示例：
# REDIS_URL=redis://:REDIS_PASSWORD@redis.internal:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
# 生产环境示例：
# RABBITMQ_URL=amqp://prod_user:STRONG_PASSWORD@rabbitmq.internal:5672/
# CELERY_BROKER_URL=amqp://prod_user:STRONG_PASSWORD@rabbitmq.internal:5672/

# ── MinIO 文件存储 ─────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin     # 生产环境必须修改
MINIO_BUCKET=adaptive-learning

# ── JWT 鉴权 ──────────────────────────────────────────────────
# 生产环境必须替换为强随机字符串：openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION

# ── LLM / OpenAI ──────────────────────────────────────────────
# 必填：填写你的 OpenAI API Key（或兼容 API 的密钥）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 如使用 Azure OpenAI 或代理，修改此地址：
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认使用的模型（复杂对话）
LLM_DEFAULT_MODEL=gpt-4o

# Embedding 模型
EMBEDDING_MODEL=text-embedding-3-small

# 每日 Token 预算上限（超出后暂停批量任务）
DAILY_TOKEN_BUDGET=2000000

# ── 知识归一化阈值 ────────────────────────────────────────────
# 跨层去重阈值（宽松：0.88，优先减少冗余）
CROSS_LAYER_THRESHOLD=0.88
# 同层归一阈值（严格：0.94，防止错误合并）
SAME_LAYER_THRESHOLD=0.94

# ── 教程质量配置 ──────────────────────────────────────────────
# 段落连贯性 embedding 相似度阈值（初始保守值 0.4，需根据真实数据校准）
COHERENCE_EMBEDDING_THRESHOLD=0.4
