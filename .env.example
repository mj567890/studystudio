# =============================================================================
# StudyStudio 环境变量配置
# 使用方法：cp .env.example .env，然后填写实际值
# 警告：.env 已加入 .gitignore，禁止提交到版本控制
# =============================================================================

# ── 应用基础 ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# ── 端口（宿主机对外暴露端口，按需修改） ──────────────────────────────
WEB_PORT=3000
API_PORT=8000
PG_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Docker 子网（可选，仅当 172.17 冲突时需配置） ──────────────────
# 解决方式：创建 docker-compose.override.yml，在其中定义 networks.default
# 安装脚本会自动检测并引导配置，详见 INSTALL.md

# ── 数据库（容器内部地址，保持 container_name 不变） ──────────────────
# 安全审计 2026-04-27：凭据已外部化为变量，生产环境请修改
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=adaptive_learning
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ / Celery ─────────────────────────────────────────────────────
# 安全审计 2026-04-27：凭据已外部化为变量，生产环境请修改默认值
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/

# ── MinIO 文件存储 ───────────────────────────────────────────────────────
# 安全审计 2026-04-27：凭据已外部化为变量，生产环境必须修改默认值
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin     # 生产环境必须修改
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=adaptive-learning
# MinIO 外部访问地址（生成预签名下载 URL 时替换容器内网地址为此外部地址）
# 如果浏览器无法直连 MinIO，可改为 Nginx 反向代理地址
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ── JWT 鉴权 ──────────────────────────────────────────────────────────────
# 安全审计 2026-04-27：生产环境必须替换为强随机字符串
# 生成方式：openssl rand -hex 32
# 默认值 "" 会导致非 development 环境启动失败
JWT_SECRET_KEY=

# ── LLM / AI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
DAILY_TOKEN_BUDGET=2000000

# ── AI 配置加密密钥 ──────────────────────────────────────────────────────
# 生成方式: python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# ⚠ 切勿丢失：丢失 = 所有已加密的 API Key 作废，需在管理后台重新填写
# 安全审计 2026-04-27：务必替换为随机生成的密钥
AI_CONFIG_ENCRYPTION_KEY=

# ── 知识归一化阈值 ──────────────────────────────────────────────────────
CROSS_LAYER_THRESHOLD=0.88
SAME_LAYER_THRESHOLD=0.94
COHERENCE_EMBEDDING_THRESHOLD=0.4
