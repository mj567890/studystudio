# =============================================================================
# StudyStudio 环境变量配置模板
# 使用方法：cp .env.example .env，然后修改标记为 <必填> 的字段
# 警告：.env 已加入 .gitignore，禁止提交到版本控制
# =============================================================================

# ── 应用基础 ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | test | production
APP_DEBUG=true               # 生产环境必须设为 false

# ── 端口（宿主机对外暴露端口，按需修改） ──────────────────────────────────
WEB_PORT=3000
API_PORT=8000
PG_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── PostgreSQL 容器初始化凭据 ──────────────────────────────────────────────
POSTGRES_DB=adaptive_learning
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
# API 服务使用的数据库连接串（容器内部地址，保持 container_name 不变）
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ 容器初始化凭据 ───────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/

# ── MinIO 容器初始化凭据 ──────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin     # 生产环境必须修改
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=adaptive-learning
# MinIO 外部访问地址（生成预签名下载 URL 时替换容器内网地址为外部地址）
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ── JWT 鉴权（必填） ──────────────────────────────────────────────────────
# 生成方式：openssl rand -hex 32
# 留空会导致非 development 环境启动失败
JWT_SECRET_KEY=

# ── AI 配置加密密钥（必填） ───────────────────────────────────────────────
# 生成方式：
#   python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# ⚠ 切勿丢失：丢失 = 所有已加密的 API Key 作废，需在管理后台重新填写
AI_CONFIG_ENCRYPTION_KEY=

# ── LLM / AI（必填） ──────────────────────────────────────────────────────
# 填写你的 API Key（OpenAI 或兼容接口）
OPENAI_API_KEY=sk-your-key-here
# OpenAI 兼容 API 地址（使用 DeepSeek/Azure/代理时修改）
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认模型
LLM_DEFAULT_MODEL=gpt-4o
# Embedding 模型
EMBEDDING_MODEL=text-embedding-3-small
# 每日 Token 预算上限（超出后暂停批量任务）
DAILY_TOKEN_BUDGET=2000000

# ── 知识归一化阈值 ────────────────────────────────────────────────────────
CROSS_LAYER_THRESHOLD=0.88        # 跨层去重阈值（宽松，优先减少冗余）
SAME_LAYER_THRESHOLD=0.94         # 同层归一阈值（严格，防止错误合并）
COHERENCE_EMBEDDING_THRESHOLD=0.4 # 段落连贯性相似度阈值
